<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/local_hosts_item_bg"
    android:gravity="center_vertical"
    android:layout_marginTop="6dp"
    android:layout_marginBottom="6dp"
    android:minHeight="56dp"
    android:orientation="horizontal"
    android:paddingStart="12dp"
    android:paddingTop="10dp"
    android:paddingEnd="12dp"
    android:paddingBottom="10dp">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_profile_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#111111"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/tv_profile_meta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="#666666"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tv_profile_conflict"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="#D32F2F"
            android:textSize="12sp"
            android:visibility="gone" />
    </LinearLayout>

    <com.google.android.material.switchmaterial.SwitchMaterial
        android:id="@+id/sw_profile_enabled"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />

    <ImageButton
        android:id="@+id/btn_edit_profile"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginStart="4dp"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/local_hosts_rename_profile"
        android:padding="8dp"
        android:src="@android:drawable/ic_menu_edit"
        app:tint="#1565C0" />

    <ImageButton
        android:id="@+id/btn_delete_profile"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginStart="2dp"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/local_hosts_delete_profile"
        android:padding="8dp"
        android:src="@android:drawable/ic_menu_delete"
        app:tint="#C62828" />

</LinearLayout>
